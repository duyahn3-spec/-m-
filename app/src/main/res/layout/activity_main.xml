<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0000">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A0000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <View
        android:id="@+id/bloodFlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#22FF0000"
        android:alpha="0.4" />

    <View
        android:id="@+id/fireRing"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_centerInParent="true"
        android:background="#44FF2200"
        android:alpha="0.3" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:text="💥Vợ Chú Để Anh 💥 Dz 🗿bọn mày tổn luồi OK🔥"
        android:textColor="#FF2200"
        android:textSize="32sp"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="25"
        android:letterSpacing="0.3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/title"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="⚔️ Địt mẹ đập lọ chưa ??🥀⚔️"
        android:textColor="#FF6600"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:shadowColor="#FF4500"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10"
        android:letterSpacing="0.2" />

    <Button
        android:id="@+id/toggleButton"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:background="@drawable/btn_oni"
        android:text="👹 😡Địt cụ mày thằng óc cặc😡"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="15" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/toggleButton"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="35dp"
        android:text="🔴 TRẠNG THÁI: Lọ 💦"
        android:textColor="#FF2200"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="12" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:text="◆ HDuong👑DZ🤩 ◆ vêlờ🔥"
        android:textColor="#FF4500"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:shadowColor="#FF0000"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10" />

</RelativeLayout>