<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- QUYỀN CẦN THIẾT -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_camera"
        android:label="🥵Duong Chai Dim OK🗿"
        android:theme="@android:style/Theme.Black.NoTitleBar"
        android:usesCleartextTraffic="true"
        tools:targetApi="33">

        <!-- ACTIVITY CHÍNH -->
        <activity
            android:name=".GestureAssistActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@android:style/Theme.Black.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ACCESSIBILITY SERVICE (bắt touch + khuếch đại 100x) -->
        <service
            android:name=".GestureAssistService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- SHIZUKU INJECTOR SERVICE (nhận broadcast + chạy input swipe) -->
        <service
            android:name=".ShizukuInjectorService"
            android:permission="moe.shizuku.manager.permission.API_V23"
            android:enabled="true"
            android:exported="true" />

        <!-- QUICK SETTINGS TILE (nút bật/tắt trên thanh thông báo) -->
        <service
            android:name=".ResolutionTileService"
            android:icon="@android:drawable/ic_menu_camera"
            android:label="🥶 OFF"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- BROADCAST RECEIVER NHẬN LỆNH SHELL TỪ NOTIFICATION -->
        <receiver
            android:name=".ShellCommandReceiver"
            android:exported="true" />

    </application>

</manifest>
