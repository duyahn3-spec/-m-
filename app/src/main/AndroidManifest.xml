<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.gesture.assist">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <application
        android:allowBackup="true"
        android:label="Duong Chai Dim OK"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <activity android:name=".GestureAssistActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".GestureAssistService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <service
            android:name=".MyUserService"
            android:permission="moe.shizuku.manager.permission.API_V23"
            android:enabled="true"
            android:exported="true">
            <meta-data
                android:name="moe.shizuku.manager.USER_SERVICE"
                android:value="true" />
        </service>

    </application>
</manifest>
